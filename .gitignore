# Rust build cache
/target

# Build staging — objcopy/hex-to-uf2 write .hex + .uf2 here; `just build` then
# moves the final .uf2(s) into firmware/<datetime>/. Throwaway, never committed.
/build/

# Built firmware snapshots — local keepsakes, regenerate with `just build`.
/firmware/

# Python bytecode (keymap docs generator)
scripts/__pycache__/

# macOS
.DS_Store

# NOTE: yuyudhan-1_keymap.svg and yuyudhan-1-viewer.html are intentionally NOT
# ignored — they are the rendered keymap documentation (tracked in git, like the
# ZMK repo's committed keymap image). Regenerate with `just docs svg|html`.
